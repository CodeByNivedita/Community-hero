rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Only admin can delete users
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if true; // Anyone can view reports
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Allow users to upvote or add comments, admins can change status
      allow delete: if isAdmin(); // Only admin/authorities can delete/reject reports
    }
    
    // Audit Logs
    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Gamification & XP
    match /gamification/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server side actions only
    }
  }
}
